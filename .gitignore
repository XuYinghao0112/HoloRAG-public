# Byte-compiled files and Python caches
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments and local environment variables
.venv/
venv/
env/
ENV/
.env
.env.*

# Build and packaging artifacts
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Test, lint, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Notebook checkpoints
.ipynb_checkpoints/

# Logs and runtime files
logs/
*.log
*.out
*.err
nohup.out

# Generated experiment outputs
outputs/
results/
figures/experiments/

# Generated indexes and retrieval caches
*.pkl
*.pickle
*.faiss
*.index
*.sqlite
*.db

# Model checkpoints and large model artifacts
models/
checkpoints/
*.bin
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# Large raw datasets; keep small canonical JSON files tracked
dataset/hotpotqa_full/
*.parquet
*.arrow

# Editor and OS files
.vscode/
.idea/
.DS_Store
Thumbs.db
