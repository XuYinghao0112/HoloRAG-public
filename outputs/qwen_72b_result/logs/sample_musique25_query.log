    },
    {
      "node_id": "chunk:port_blair_0",
      "passage_index": 2,
      "title": "Port Blair",
      "score": 0.04091250108676817,
      "text": "Port Blair\nPort Blair (pronunciation (help info)) is the capital of the Andaman and Nicobar Islands, a union territory of India situated in the Bay of Bengal. It is also the local administrative sub-division (tehsil) of the islands, the headquarters for the district of South Andaman, and is the territory's only notified town. It houses the headquarters of the Andaman and Nicobar Police and the Andaman and Nicobar Command, the first integrated tri-command of the armed forces of India.",
      "score_breakdown": {
