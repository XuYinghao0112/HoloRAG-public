    },
    {
      "node_id": "chunk:national_insurance_number_0",
      "passage_index": 13,
      "title": "National Insurance number",
      "score": 0.0643602557295708,
      "text": "National Insurance number\nPeople born and resident in the UK are assigned a Child Reference Number shortly after birth when a claim is made for Child Benefit. At age 15 years 9 months HM Revenue and Customs (HMRC) notifies each child of their NI number.",
      "score_breakdown": {
