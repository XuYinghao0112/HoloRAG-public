      }
    },
    {
      "node_id": "chunk:list_of_bombardier_crj_operators_0",
      "passage_index": 5,
      "title": "List of Bombardier CRJ operators",
      "score": 0.09178389866464264,
      "text": "List of Bombardier CRJ operators\nProduced by Bombardier Aerospace, aerospace division of the Canadian aerospace and defence company Bombardier Inc. the former CRJ100 and CRJ200 series are no longer in production but still in active airline service, while the more recent CRJ700, CRJ900 and CRJ1000 series are in production and in service.",
      "score_breakdown": {
        "dense": 0.05033699433787494,
        "graph": 0.053162195468519156,
