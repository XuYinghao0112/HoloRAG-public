    {
      "node_id": "chunk:comcast_sports_southwest_0",
      "passage_index": 5,
      "title": "Comcast Sports Southwest",
      "score": 0.041763933157773755,
      "text": "Comcast Sports Southwest\nComcast Sports Southwest (CSS) was an American regional sports network that served Greater Houston, Texas. It was owned by the NBC Sports Group unit of NBCUniversal. The channel was launched on September 1, 2009 and had a similar format to Comcast/Charter Sports Southeast, which launched ten years earlier. Both networks shared the same logo and focused primarily on collegiate and high school sports.",
      "score_breakdown": {
        "dense": 0.04998225924342481,
        "graph": 0.04757896857963368,
        "fact": 0.0
      }
    },
    {
      "node_id": "chunk:premier_league_0",
      "passage_index": 14,
      "title": "Premier League",
      "score": 0.04164561180419452,
      "text": "Premier League\nThe Premier League is particularly popular in Asia, where it is the most widely distributed sports programme. In Australia, Fox Sports broadcasts almost all of the season's 380 matches live, and Foxtel gives subscribers the option of selecting which Saturday 3pm match to watch. In India, the matches are broadcast live on STAR Sports. In China, the broadcast rights were awarded to Super Sports in a six-year agreement that began in the 2013–14 season. As of the 2013–14 season, Canadian broadcast rights to the Premier League are jointly owned by Sportsnet and TSN, with both rival networks holding rights to 190 matches per season.",
      "score_breakdown": {
        "dense": 0.04991485801027164,
        "graph": 0.0473081329951504,
        "fact": 0.0
      }
    },
    {
      "node_id": "chunk:wfan_fm_0",
      "passage_index": 10,
      "title": "WFAN-FM",
      "score": 0.04164515054229033,
      "text": "WFAN-FM\nWFAN-FM (101.9 MHz), also known as \"Sports Radio 66 and 101.9 FM\" or \"The Fan\", is a commercial FM sports radio station licensed to New York City. The station is owned and operated by Entercom, and is simulcast with WFAN (660 AM). WFAN-FM's studios are located in the combined Entercom facility in the Hudson Square neighborhood of Manhattan and its transmitter is located at the Empire State Building.",
      "score_breakdown": {
        "dense": 0.05021648531685232,
        "graph": 0.04675361206007185,
        "fact": 0.0
      }
    }
