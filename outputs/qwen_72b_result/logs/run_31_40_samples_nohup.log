  "ranked_passages": [
    {
      "node_id": "chunk:hannibal_and_scipio_0",
      "passage_index": 12,
      "title": "Hannibal and Scipio",
      "score": 0.12148577302712762,
      "text": "Hannibal and Scipio\nHannibal and Scipio is a Caroline era stage play, a classical tragedy written by Thomas Nabbes. The play was first performed in 1635 by Queen Henrietta's Men, and was first published in 1637. The first edition of the play contained a cast list of the original production, making the 1637 quarto an important information source on English Renaissance theatre.",
      "score_breakdown": {
        "dense": 0.050463436099553886,
        "graph": 0.05564976555307225,
        "fact": 0.513573023376342
