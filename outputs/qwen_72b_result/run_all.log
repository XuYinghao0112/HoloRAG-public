    {
      "node_id": "chunk:dog_star_man_0",
      "passage_index": 13,
      "title": "Dog Star Man",
      "score": 0.11748351895111156,
      "text": "Dog Star Man\nDog Star Man is a series of short experimental films, all directed by Stan Brakhage, featuring Jane Wodening. It was released during 1961 to 1964 and comprises a prelude and four parts.",
      "score_breakdown": {
        "dense": 0.049783627587473296,
        "graph": 0.05375769299666438,
        "fact": 0.493168105860013
