    {
      "node_id": "chunk:history_of_australia_0",
      "passage_index": 12,
      "title": "History of Australia",
      "score": 0.044905248150816465,
      "text": "History of Australia\nThe Federal Capital Territory (FCT) was formed from New South Wales in 1911 to provide a location for the proposed new federal capital of Canberra (Melbourne was the seat of government from 1901 to 1927). The FCT was renamed the Australian Capital Territory (ACT) in 1938. The Northern Territory was transferred from the control of the South Australian government to the Commonwealth in 1911.",
      "score_breakdown": {
        "dense": 0.052238712962999416,
        "graph": 0.0539131867372226,
        "fact": 0.0
      }
    },
    {
      "node_id": "chunk:redwood_county_poor_farm_0",
      "passage_index": 19,
      "title": "Redwood County Poor Farm",
      "score": 0.04458051036769187,
      "text": "Redwood County Poor Farm\nThe Redwood County Poor Farm (or Poorhouse) was a county run institution serving impoverished and aged people in Redwood Falls, Minnesota, United States, from 1884 to 1889 and again from 1909 to 1967, when it was converted to a nursing home.",
      "score_breakdown": {
        "dense": 0.05272929711638233,
        "graph": 0.051931323178938615,
        "fact": 0.0
      }
    },
